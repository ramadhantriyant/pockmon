.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace

# IDE - JetBrains
.idea/
*.iml
*.iws
*.ipr

# IDE - Vim
*.swp
*.swo
*~

# OS files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Build output
/bin/
/dist/
/build/

# Compiled binary
pockmon

# Temporary files
*.tmp
*.log

# Database files (if using local SQLite)
*.db
*.sqlite
*.sqlite3

# Air (live reload) temporary files
tmp/
